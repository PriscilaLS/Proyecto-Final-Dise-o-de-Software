<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ClientLocal.Views.Decorator.DecoratorDemoView">
  <Border Background="#0f172a" Padding="28">
    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" ColumnDefinitions="*,*">
      <StackPanel Grid.ColumnSpan="2" Spacing="6" Margin="0,0,0,20">
        <TextBlock Text="Demo Patr&#243;n Decorator - Script"
                   FontSize="34"
                   FontWeight="Bold"
                   Foreground="#f8fafc"/>
        <TextBlock Text="Carga un script, visualiza syntax highlight y verifica su firma."
                   Foreground="#9db3ca"/>
      </StackPanel>

      <StackPanel Grid.Row="1"
                  Grid.ColumnSpan="2"
                  Orientation="Horizontal"
                  Spacing="10"
                  Margin="0,0,0,18">
        <Button Content="Cargar Script"
                Width="140"
                Height="44"
                Background="#38bdf8"
                Foreground="#082f49"
                FontWeight="Bold"
                Click="LoadScriptButton_Click"/>
        <Button Content="Firmar"
                Width="120"
                Height="44"
                Background="#263449"
                Foreground="#f8fafc"
                FontWeight="Bold"
                Click="SignButton_Click"/>
        <Button Content="Verificar Firma"
                Width="150"
                Height="44"
                Background="#263449"
                Foreground="#f8fafc"
                FontWeight="Bold"
                Click="VerifyButton_Click"/>
        <Button Content="Regenerar Firma"
                Width="160"
                Height="44"
                Background="#263449"
                Foreground="#f8fafc"
                FontWeight="Bold"
                Click="RegenerateButton_Click"/>
      </StackPanel>

      <Border Grid.Row="2"
              Grid.ColumnSpan="2"
              Background="#162235"
              BorderBrush="#24344f"
              BorderThickness="1"
              CornerRadius="16"
              Padding="16"
              Margin="0,0,0,18">
        <StackPanel Spacing="8">
          <TextBlock x:Name="PathTextBlock"
                     Foreground="#f8fafc"
                     TextWrapping="Wrap"
                     Text="Ruta: sin archivo cargado"/>
          <TextBlock x:Name="StatusTextBlock"
                     Foreground="#fbbf24"
                     FontWeight="SemiBold"
                     TextWrapping="Wrap"
                     Text="Estado de firma: No firmado"/>
        </StackPanel>
      </Border>

      <Border Grid.Row="3"
              Grid.Column="0"
              Margin="0,0,12,0"
              Background="#162235"
              BorderBrush="#24344f"
              BorderThickness="1"
              CornerRadius="16"
              Padding="16">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Text="Texto original"
                     Foreground="#f8fafc"
                     FontWeight="Bold"
                     Margin="0,0,0,10"/>
          <TextBox x:Name="PlainTextBox"
                   Grid.Row="1"
                   IsReadOnly="True"
                   AcceptsReturn="True"
                   TextWrapping="NoWrap"
                   Background="#0f172a"
                   Foreground="#f8fafc"
                   BorderBrush="#334155"
                   FontFamily="Consolas"
                   ScrollViewer.HorizontalScrollBarVisibility="Auto"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"/>
        </Grid>
      </Border>

      <Border Grid.Row="3"
              Grid.Column="1"
              Margin="12,0,0,0"
              Background="#162235"
              BorderBrush="#24344f"
              BorderThickness="1"
              CornerRadius="16"
              Padding="16">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Text="Texto con syntax highlight"
                     Foreground="#f8fafc"
                     FontWeight="Bold"
                     Margin="0,0,0,10"/>
          <Border Grid.Row="1"
                  Background="#0f172a"
                  BorderBrush="#334155"
                  BorderThickness="1"
                  CornerRadius="10"
                  Padding="12">
            <SelectableTextBlock x:Name="HighlightedTextBlock"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas"
                                 Foreground="#f8fafc"/>
          </Border>
        </Grid>
      </Border>

      <TextBlock Grid.Row="4"
                 Grid.ColumnSpan="2"
                 x:Name="SignatureInfoTextBlock"
                 Margin="0,16,0,0"
                 Foreground="#9db3ca"
                 TextWrapping="Wrap"
                 Text="Firma almacenada: sin informaci&#243;n"/>
    </Grid>
  </Border>
</UserControl>

