<Window x:Class="ClientLocal.Views.Auth.RegisterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registro" Height="470" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Crear cuenta"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Nombre"/>
            <TextBox x:Name="NombreTextBox" Height="28"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Primer apellido"/>
            <TextBox x:Name="Apellido1TextBox" Height="28"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Segundo apellido"/>
            <TextBox x:Name="Apellido2TextBox" Height="28"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="Carnet"/>
            <TextBox x:Name="CarnetTextBox" Height="28"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="0,0,0,10">
            <TextBlock Text="Correo"/>
            <TextBox x:Name="CorreoTextBox" Height="28"/>
        </StackPanel>

        <StackPanel Grid.Row="6" Margin="0,0,0,10">
            <TextBlock Text="Contraseña"/>
            <PasswordBox x:Name="ContrasenaPasswordBox" Height="28"/>
        </StackPanel>

        <StackPanel Grid.Row="7">
            <TextBlock x:Name="EstadoTextBlock"
                       Foreground="Red"
                       Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Volver"
                        Width="100"
                        Margin="0,0,10,0"
                        Click="VolverLogin_Click"/>
                <Button Content="Registrar"
                        Width="100"
                        Click="Registrar_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>