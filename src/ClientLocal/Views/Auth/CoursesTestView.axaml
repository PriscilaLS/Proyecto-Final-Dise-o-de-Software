<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:ClientLocal.Models.Courses"
             x:Class="ClientLocal.Views.Auth.CoursesTestView">
  <Border Background="#0f172a" Padding="28">
    <Grid RowDefinitions="Auto,Auto,*,Auto">
      <Grid ColumnDefinitions="*,Auto"
            Margin="0,0,0,24">
        <StackPanel Spacing="4">
          <TextBlock Text="Cursos matriculados"
                     FontSize="34"
                     FontWeight="Bold"
                     Foreground="#f8fafc"/>
          <TextBlock Text="Consulta tus cursos, tareas y abre el IDE local."
                     Foreground="#9db3ca"/>
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="10"
                    VerticalAlignment="Bottom">
          <Button Content="Ver tareas"
                  Width="130"
                  Height="42"
                  Background="#38bdf8"
                  Foreground="#082f49"
                  FontWeight="Bold"
                  Click="OpenTasksButton_Click"/>
          <Button Content="Abrir IDE"
                  Width="120"
                  Height="42"
                  Background="#263449"
                  Foreground="#f8fafc"
                  FontWeight="Bold"
                  Click="OpenIdeButton_Click"/>
          <Button Content="Decorator"
                  Width="120"
                  Height="42"
                  Background="#263449"
                  Foreground="#f8fafc"
                  FontWeight="Bold"
                  Click="OpenDecoratorButton_Click"/>
        </StackPanel>
      </Grid>

      <Border Grid.Row="1"
              Background="#162235"
              BorderBrush="#24344f"
              BorderThickness="1"
              CornerRadius="16"
              Padding="18"
              Margin="0,0,0,20">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
          <TextBox x:Name="JoinCodeTextBox"
                   Height="44"
                   CornerRadius="10"
                   Background="#0f172a"
                   Foreground="#f8fafc"
                   BorderBrush="#334155"
                   PlaceholderText="C&#243;digo del curso"/>
          <Button Grid.Column="1"
                  Content="Unirse al curso"
                  Width="160"
                  Height="44"
                  Background="#38bdf8"
                  Foreground="#082f49"
                  FontWeight="Bold"
                  Click="JoinCourseButton_Click"/>
        </Grid>
      </Border>

      <ListBox x:Name="CoursesListBox"
               Grid.Row="2"
               Background="Transparent"
               BorderThickness="0">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="models:CourseDto">
            <Border Margin="0,0,0,12"
                    Padding="18"
                    Background="#1e293b"
                    BorderBrush="#24344f"
                    BorderThickness="1"
                    CornerRadius="16">
              <StackPanel Spacing="6">
                <TextBlock Text="{Binding Name}"
                           Foreground="#f8fafc"
                           FontWeight="Bold"
                           FontSize="18"/>
                <TextBlock Text="{Binding Description}"
                           Foreground="#cbd5e1"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding JoinCode, StringFormat='C&#243;digo: {0}'}"
                           IsVisible="{Binding ShowJoinCode}"
                           Foreground="#38bdf8"
                           FontWeight="SemiBold"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <TextBlock x:Name="StatusTextBlock"
                 Grid.Row="3"
                 Margin="0,16,0,0"
                 Foreground="#fbbf24"
                 TextWrapping="Wrap"/>
    </Grid>
  </Border>
</UserControl>

