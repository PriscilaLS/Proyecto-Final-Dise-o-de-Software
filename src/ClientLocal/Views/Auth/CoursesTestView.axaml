<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:ClientLocal.Models.Courses"
             x:Class="ClientLocal.Views.Auth.CoursesTestView">
  <Border Padding="24">
    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
      <TextBlock Text="Cursos matriculados"
                 FontSize="24"
                 FontWeight="Bold"
                 Margin="0,0,0,16"/>

      <StackPanel Grid.Row="1"
                  Orientation="Horizontal"
                  Spacing="10"
                  Margin="0,0,0,16">
        <TextBox x:Name="JoinCodeTextBox"
                 Width="260"
                 Watermark="Código del curso"/>
        <Button Content="Unirse al curso"
                Width="150"
                Click="JoinCourseButton_Click"/>
      </StackPanel>

      <StackPanel Grid.Row="2"
                  Orientation="Horizontal"
                  Spacing="10"
                  Margin="0,0,0,16">
        <Button Content="Ver tareas del curso"
                Width="170"
                Click="OpenTasksButton_Click"/>
        <Button Content="Abrir IDE"
                Width="130"
                Click="OpenIdeButton_Click"/>
        <Button Content="Demo Decorator"
                Width="150"
                Click="OpenDecoratorButton_Click"/>
      </StackPanel>

      <ListBox x:Name="CoursesListBox"
               Grid.Row="3">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="models:CourseDto">
            <Border Margin="0,0,0,10"
                    Padding="12"
                    Background="#111827"
                    CornerRadius="10">
              <StackPanel>
                <TextBlock Text="{Binding Name}"
                           FontWeight="Bold"
                           FontSize="16"/>
                <TextBlock Text="{Binding Description}"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding JoinCode, StringFormat='Código: {0}'}"
                           Margin="0,6,0,0"
                           Foreground="LightGray"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <TextBlock x:Name="StatusTextBlock"
                 Grid.Row="4"
                 Margin="0,16,0,0"
                 Foreground="Orange"
                 TextWrapping="Wrap"/>
    </Grid>
  </Border>
</UserControl>