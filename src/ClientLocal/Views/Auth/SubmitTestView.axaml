<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:submission="clr-namespace:ClientLocal.Models.Submission"
             x:Class="ClientLocal.Views.Auth.SubmitTestView">
  <Border Background="#0f172a" Padding="28">
    <Grid RowDefinitions="Auto,Auto,Auto,*">
      <StackPanel Spacing="4" Margin="0,0,0,24">
        <TextBlock x:Name="TitleTextBlock"
                   FontSize="34"
                   FontWeight="Bold"
                   Foreground="#f8fafc"/>
        <TextBlock Text="Selecciona la carpeta del proyecto, firma los scripts, envia la entrega y revisa el historial de versiones."
                   Foreground="#9db3ca"
                   TextWrapping="Wrap"/>
      </StackPanel>

      <Border Grid.Row="1"
              Background="#162235"
              BorderBrush="#24344f"
              BorderThickness="1"
              CornerRadius="16"
              Padding="18"
              Margin="0,0,0,16">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto"
            ColumnDefinitions="*,Auto"
            ColumnSpacing="12"
            RowSpacing="8">

          <TextBlock Grid.ColumnSpan="2"
                    Text="Carpeta del proyecto"
                    Foreground="#cbd5e1"
                    FontWeight="SemiBold"/>

          <TextBox x:Name="ProjectPathTextBox"
                  Grid.Row="1"
                  Height="44"
                  IsReadOnly="True"
                  CornerRadius="10"
                  Background="#0f172a"
                  Foreground="#f8fafc"
                  BorderBrush="#334155"/>

          <Button Grid.Row="1"
                  Grid.Column="1"
                  Content="Elegir carpeta"
                  Width="150"
                  Height="44"
                  Background="#38bdf8"
                  Foreground="#082f49"
                  FontWeight="Bold"
                  Click="PickFolderButton_Click"/>

          <TextBlock Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Text="Archivo adicional (opcional)"
                    Foreground="#cbd5e1"
                    FontWeight="SemiBold"/>

          <TextBox x:Name="ExternalFileTextBox"
                  Grid.Row="3"
                  Height="44"
                  IsReadOnly="True"
                  CornerRadius="10"
                  Background="#0f172a"
                  Foreground="#f8fafc"
                  BorderBrush="#334155"/>

          <Button Grid.Row="3"
                  Grid.Column="1"
                  Content="Elegir archivo"
                  Width="150"
                  Height="44"
                  Background="#38bdf8"
                  Foreground="#082f49"
                  FontWeight="Bold"
                  Click="PickExternalFileButton_Click"/>
      </Grid>
        </Grid>
      </Border>

      <StackPanel Grid.Row="2"
                  Orientation="Horizontal"
                  Spacing="10"
                  Margin="0,0,0,18">
        <Button Content="Firmar proyecto"
                Width="150"
                Height="44"
                Background="#263449"
                Foreground="#f8fafc"
                FontWeight="Bold"
                Click="SignButton_Click"/>
        <Button Content="Validar firmas"
                Width="150"
                Height="44"
                Background="#263449"
                Foreground="#f8fafc"
                FontWeight="Bold"
                Click="ValidateButton_Click"/>
        <Button Content="Enviar entrega"
                Width="150"
                Height="44"
                Background="#38bdf8"
                Foreground="#082f49"
                FontWeight="Bold"
                Click="SubmitButton_Click"/>
        <Button Content="Actualizar historial"
                Width="170"
                Height="44"
                Background="#263449"
                Foreground="#f8fafc"
                FontWeight="Bold"
                Click="RefreshHistoryButton_Click"/>
        <Button Content="Abrir IDE"
                Width="150"
                Height="44"
                Background="#263449"
                Foreground="#f8fafc"
                FontWeight="Bold"
                Click="OpenIdeButton_Click"/>
        <Button Content="Volver"
                Width="120"
                Height="44"
                Background="#263449"
                Foreground="#f8fafc"
                FontWeight="Bold"
                Click="BackButton_Click"/>
        <Button Content="Volver a cursos"
                Width="150"
                Height="44"
                Background="#263449"
                Foreground="#f8fafc"
                FontWeight="Bold"
                Click="BackToCoursesButton_Click"/>
      </StackPanel>

      <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="16">
        <Border Background="#162235"
                BorderBrush="#24344f"
                BorderThickness="1"
                CornerRadius="16"
                Padding="18">
          <StackPanel Spacing="12">
            <TextBlock Text="Resultado de entrega"
                       Foreground="#f8fafc"
                       FontSize="18"
                       FontWeight="Bold"/>
            <TextBlock x:Name="StatusTextBlock"
                       Foreground="#f87171"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"/>
            <TextBlock x:Name="ResultTextBlock"
                       Foreground="#f8fafc"
                       TextWrapping="Wrap"/>
          </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="#162235"
                BorderBrush="#24344f"
                BorderThickness="1"
                CornerRadius="16"
                Padding="18">
          <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
            <TextBlock Text="Historial de versiones"
                       Foreground="#f8fafc"
                       FontSize="18"
                       FontWeight="Bold"/>
            <TextBlock x:Name="HistoryStatusTextBlock"
                       Grid.Row="1"
                       Foreground="#9db3ca"
                       TextWrapping="Wrap"/>
            <ListBox x:Name="VersionsListBox"
                     Grid.Row="2"
                     Background="Transparent"
                     BorderThickness="0">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="submission:SubmissionVersionDto">
                  <Border Margin="0,0,0,10"
                          Padding="12"
                          Background="#0f172a"
                          BorderBrush="#334155"
                          BorderThickness="1"
                          CornerRadius="12">
                    <StackPanel Spacing="4">
                      <TextBlock Text="{Binding DisplayText}"
                                 Foreground="#f8fafc"
                                 FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding FilePath}"
                                 Foreground="#9db3ca"
                                 FontSize="12"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Border>
</UserControl>
