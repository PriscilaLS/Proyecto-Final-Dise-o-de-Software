<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:ClientLocal.Models.Tasks"
             x:Class="ClientLocal.Views.Auth.TasksTestView">
  <Border Background="#0f172a" Padding="28">
    <Grid RowDefinitions="Auto,*,Auto">
      <StackPanel Spacing="4" Margin="0,0,0,24">
        <TextBlock x:Name="TitleTextBlock"
                   FontSize="34"
                   FontWeight="Bold"
                   Foreground="#f8fafc"/>
        <TextBlock Text="Selecciona una tarea para revisar sus detalles o hacer una entrega."
                   Foreground="#9db3ca"/>
      </StackPanel>

      <ListBox x:Name="TasksListBox"
               Grid.Row="1"
               Background="Transparent"
               BorderThickness="0"
               SelectionChanged="TasksListBox_SelectionChanged">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="models:TaskDto">
            <Border Margin="0,0,0,12"
                    Padding="18"
                    Background="#1e293b"
                    BorderBrush="#24344f"
                    BorderThickness="1"
                    CornerRadius="16">
              <TextBlock Text="{Binding Title}"
                         Foreground="#f8fafc"
                         FontSize="18"
                         FontWeight="Bold"/>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <Border Grid.Row="2"
              Background="#162235"
              BorderBrush="#24344f"
              BorderThickness="1"
              CornerRadius="16"
              Padding="18"
              Margin="0,18,0,0">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
          <StackPanel Spacing="8">
            <TextBlock x:Name="DetailsTextBlock"
                       Foreground="#f8fafc"
                       TextWrapping="Wrap"/>
            <TextBlock x:Name="StatusTextBlock"
                       Foreground="#f87171"
                       TextWrapping="Wrap"/>
          </StackPanel>
          <StackPanel Grid.Column="1"
                      Spacing="10"
                      VerticalAlignment="Center">
            <Button Content="Ir a entrega"
                    Width="150"
                    Height="44"
                    Background="#38bdf8"
                    Foreground="#082f49"
                    FontWeight="Bold"
                    Click="GoToSubmitButton_Click"/>
            <Button Content="Volver a cursos"
                    Width="150"
                    Height="44"
                    Background="#263449"
                    Foreground="#f8fafc"
                    FontWeight="Bold"
                    Click="BackToCoursesButton_Click"/>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Border>
</UserControl>

