<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ClientLocal.Views.VersionControl.GitToolWindow"
        Width="1180"
        Height="780"
        MinWidth="980"
        MinHeight="680"
        Title="Git controlado - EduIDE">
  <Border Background="#0f172a" Padding="28">
    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="16">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
        <StackPanel Spacing="6">
          <TextBlock Text="Git controlado"
                     FontSize="38"
                     FontWeight="Bold"
                     Foreground="#f8fafc"/>
          <TextBlock Text="Guarda versiones locales del proyecto y revisa cambios sin permitir operaciones remotas riesgosas."
                     Foreground="#9db3ca"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
          <Button Content="Pull"
                  Width="86"
                  Height="38"
                  Background="#263449"
                  Foreground="#94a3b8"
                  IsEnabled="False"
                  ToolTip.Tip="Pull descarga cambios desde un repositorio remoto. Esta demo lo bloquea para evitar codigo externo durante una evaluacion."/>
          <Button Content="Push"
                  Width="86"
                  Height="38"
                  Background="#263449"
                  Foreground="#94a3b8"
                  IsEnabled="False"
                  ToolTip.Tip="Push sube commits a GitHub u otro remoto. Esta demo mantiene Git local para que sea controlado y defendible."/>
        </StackPanel>
      </Grid>

      <Border Grid.Row="1"
              Background="#162235"
              BorderBrush="#24344f"
              BorderThickness="1"
              CornerRadius="16"
              Padding="18">
        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto,Auto" RowSpacing="10" ColumnSpacing="12">
          <StackPanel>
            <TextBlock Text="Carpeta del proyecto"
                       Foreground="#f8fafc"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>
            <TextBox x:Name="ProjectPathTextBox"
                     Height="44"
                     CornerRadius="10"
                     Background="#0f172a"
                     Foreground="#f8fafc"
                     BorderBrush="#334155"
                     IsReadOnly="True"
                     PlaceholderText="Selecciona una carpeta local"/>
          </StackPanel>

          <Button Grid.Column="1"
                  Content="Elegir carpeta"
                  Width="156"
                  Height="44"
                  VerticalAlignment="Bottom"
                  Background="#38bdf8"
                  Foreground="#082f49"
                  FontWeight="Bold"
                  ToolTip.Tip="Selecciona la carpeta del proyecto que quieres revisar con Git."
                  Click="PickFolderButton_Click"/>

          <Button Grid.Column="2"
                  Content="Inicializar Git"
                  Width="160"
                  Height="44"
                  VerticalAlignment="Bottom"
                  Background="#263449"
                  Foreground="#f8fafc"
                  FontWeight="Bold"
                  ToolTip.Tip="Equivale a git init. Prepara esta carpeta para guardar versiones locales."
                  Click="InitButton_Click"/>

          <TextBlock x:Name="RepositoryInfoTextBlock"
                     Grid.Row="1"
                     Grid.ColumnSpan="3"
                     Foreground="#fbbf24"
                     Text="Repositorio: sin carpeta seleccionada"
                     TextWrapping="Wrap"/>
        </Grid>
      </Border>

      <Grid Grid.Row="2" ColumnDefinitions="320,*" ColumnSpacing="16">
        <Border Background="#162235"
                BorderBrush="#24344f"
                BorderThickness="1"
                CornerRadius="16"
                Padding="16">
          <Grid RowDefinitions="Auto,Auto,*" RowSpacing="12">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel>
                <TextBlock Text="Cambios"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#f8fafc"/>
                <TextBlock Text="Archivos modificados o nuevos"
                           Foreground="#9db3ca"
                           FontSize="13"/>
              </StackPanel>
              <Button Grid.Column="1"
                      Content="i"
                      Width="28"
                      Height="28"
                      Background="#263449"
                      Foreground="#93c5fd"
                      FontWeight="Bold"
                      ToolTip.Tip="Esta lista equivale a git status. Muestra que archivos cambiaron desde la ultima version guardada."/>
            </Grid>

            <Button Grid.Row="1"
                    Content="Actualizar cambios"
                    Height="40"
                    Background="#38bdf8"
                    Foreground="#082f49"
                    FontWeight="Bold"
                    ToolTip.Tip="Vuelve a revisar el estado del proyecto."
                    Click="StatusButton_Click"/>

            <ListBox x:Name="ChangedFilesListBox"
                     Grid.Row="2"
                     Background="#0f172a"
                     Foreground="#f8fafc"
                     BorderBrush="#334155"
                     SelectionChanged="ChangedFilesListBox_SelectionChanged"/>
          </Grid>
        </Border>

        <Border Grid.Column="1"
                Background="#020617"
                BorderBrush="#24344f"
                BorderThickness="1"
                CornerRadius="16"
                Padding="16">
          <Grid RowDefinitions="Auto,*" RowSpacing="10">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
              <StackPanel>
                <TextBlock Text="Comparacion"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#f8fafc"/>
                <TextBlock x:Name="SelectedFileTextBlock"
                           Text="Selecciona un archivo para ver su diff"
                           Foreground="#9db3ca"
                           FontSize="13"/>
              </StackPanel>
              <Button Grid.Column="1"
                      Content="Comparar todo"
                      Width="132"
                      Height="38"
                      Background="#263449"
                      Foreground="#f8fafc"
                      FontWeight="Bold"
                      ToolTip.Tip="Muestra el diff de todos los archivos modificados."
                      Click="DiffButton_Click"/>
              <Button Grid.Column="2"
                      Content="Historial"
                      Width="100"
                      Height="38"
                      Background="#263449"
                      Foreground="#f8fafc"
                      FontWeight="Bold"
                      ToolTip.Tip="Equivale a git log. Muestra las ultimas versiones guardadas."
                      Click="LogButton_Click"/>
            </Grid>

            <TextBox x:Name="OutputTextBox"
                     Grid.Row="1"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     IsReadOnly="True"
                     FontFamily="Consolas"
                     Background="#020617"
                     Foreground="#cbd5e1"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     Text="Selecciona una carpeta para comenzar.&#10;&#10;Operaciones bloqueadas por diseno: clone, pull, fetch, merge, rebase, checkout remoto y push."/>
          </Grid>
        </Border>
      </Grid>

      <Border Grid.Row="3"
              Background="#162235"
              BorderBrush="#24344f"
              BorderThickness="1"
              CornerRadius="16"
              Padding="16">
        <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="12">
          <StackPanel Spacing="6">
            <TextBlock Text="Summary"
                       Foreground="#bfdbfe"
                       FontWeight="Bold"
                       FontSize="13"/>
            <TextBox x:Name="CommitSummaryTextBox"
                     Height="42"
                     CornerRadius="10"
                     Background="#0f172a"
                     Foreground="#f8fafc"
                     BorderBrush="#334155"
                     PlaceholderText="Ej. Agrega entrega de tarea"/>
          </StackPanel>

          <StackPanel Grid.Column="1" Spacing="6">
            <TextBlock Text="Description (optional)"
                       Foreground="#bfdbfe"
                       FontWeight="Bold"
                       FontSize="13"/>
            <TextBox x:Name="CommitDescriptionTextBox"
                     Height="42"
                     CornerRadius="10"
                     Background="#0f172a"
                     Foreground="#f8fafc"
                     BorderBrush="#334155"
                     PlaceholderText="Detalle breve del cambio"/>
          </StackPanel>

          <Button Grid.Column="2"
                  Content="Commit"
                  Width="130"
                  Height="42"
                  Background="#38bdf8"
                  Foreground="#082f49"
                  FontWeight="Bold"
                  ToolTip.Tip="Guarda una version local. Internamente hace git add -A y git commit."
                  Click="CommitButton_Click"/>
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
